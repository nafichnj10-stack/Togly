<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="0dp">

    <ImageView
        android:id="@+id/widget_bg"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="fitXY" />

    <LinearLayout
        android:id="@+id/layout_status"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerHorizontal="true"
        android:layout_alignParentTop="true"
        android:layout_marginTop="8dp"
        android:orientation="vertical"
        android:gravity="center">

        <TextView
            android:id="@+id/tv_status_icon"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📅"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/tv_status_line1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Next hug in"
            android:textColor="#FFFFFF"
            android:textSize="9sp"
            android:shadowColor="#AA000000"
            android:shadowDx="1"
            android:shadowDy="1"
            android:shadowRadius="4" />

        <TextView
            android:id="@+id/tv_status_line2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="43 days"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"
            android:shadowColor="#AA000000"
            android:shadowDx="1"
            android:shadowDy="1"
            android:shadowRadius="4" />

        <TextView
            android:id="@+id/tv_status_line3"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#FF69B4"
            android:textSize="8sp"
            android:shadowColor="#AA000000"
            android:shadowDx="1"
            android:shadowDy="1"
            android:shadowRadius="4" />

    </LinearLayout>

    <LinearLayout
        android:id="@+id/btn_send_love"
        android:layout_width="wrap_content"
        android:layout_height="22dp"
        android:layout_alignParentTop="true"
        android:layout_alignParentEnd="true"
        android:layout_marginTop="8dp"
        android:layout_marginEnd="14dp"
        android:orientation="horizontal"
        android:gravity="center"
        android:background="@drawable/bg_send_love"
        android:paddingStart="8dp"
        android:paddingEnd="8dp">

        <TextView
            android:id="@+id/tv_send_love_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="❤️ Send Love"
            android:textColor="#FFFFFF"
            android:textSize="7sp"
            android:textStyle="bold"
            android:shadowColor="#AA8B0050"
            android:shadowDx="0"
            android:shadowDy="1"
            android:shadowRadius="3" />

    </LinearLayout>

    <!-- ✅ FIX: bike সাইজ ১.৫× কমায় (r*4.5f → r*3f) extra space-ও কমানো হয়েছে
         (130px → 88px)। height: (60+88)*0.5333 ≈ 79dp, safety-র জন্য 80dp রাখা হলো।
         marginBottom অপরিবর্তিত — card তার নিজের জায়গাতেই থাকবে। -->
    <ImageView
        android:id="@+id/img_profile_bar"
        android:layout_width="190dp"
        android:layout_height="80dp"
        android:layout_centerHorizontal="true"
        android:layout_alignParentBottom="true"
        android:layout_marginBottom="35dp"
        android:scaleType="fitXY" />

    <!-- Left Name Card: 65x25 → 76x29 -->
    <LinearLayout
        android:id="@+id/card_name_left"
        android:layout_width="76dp"
        android:layout_height="29dp"
        android:layout_alignParentStart="true"
        android:layout_alignParentBottom="true"
        android:layout_marginStart="18dp"
        android:layout_marginBottom="7dp"
        android:orientation="vertical"
        android:gravity="center"
        android:background="@drawable/bg_name_card"
        android:paddingStart="3dp"
        android:paddingEnd="3dp">

        <TextView
            android:id="@+id/tv_name_left"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🐾 Bam"
            android:textColor="#FFFFFF"
            android:textSize="9sp"
            android:textStyle="bold"
            android:singleLine="true"
            android:shadowColor="#AA8B0050"
            android:shadowDx="0"
            android:shadowDy="1"
            android:shadowRadius="3" />

        <TextView
            android:id="@+id/tv_flag_left"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🇩🇪 Germany"
            android:textColor="#FFF0F7"
            android:textSize="8sp"
            android:singleLine="true"
            android:shadowColor="#AA8B0050"
            android:shadowDx="0"
            android:shadowDy="1"
            android:shadowRadius="3" />

    </LinearLayout>

    <!-- Right Name Card: 65x25 → 76x29 -->
    <LinearLayout
        android:id="@+id/card_name_right"
        android:layout_width="76dp"
        android:layout_height="29dp"
        android:layout_alignParentEnd="true"
        android:layout_alignParentBottom="true"
        android:layout_marginEnd="18dp"
        android:layout_marginBottom="7dp"
        android:orientation="vertical"
        android:gravity="center"
        android:background="@drawable/bg_name_card"
        android:paddingStart="3dp"
        android:paddingEnd="3dp">

        <TextView
            android:id="@+id/tv_name_right"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🐾 Mimi"
            android:textColor="#FFFFFF"
            android:textSize="9sp"
            android:textStyle="bold"
            android:singleLine="true"
            android:shadowColor="#AA8B0050"
            android:shadowDx="0"
            android:shadowDy="1"
            android:shadowRadius="3" />

        <TextView
            android:id="@+id/tv_flag_right"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🇹🇭 Thailand"
            android:textColor="#FFF0F7"
            android:textSize="8sp"
            android:singleLine="true"
            android:shadowColor="#AA8B0050"
            android:shadowDx="0"
            android:shadowDy="1"
            android:shadowRadius="3" />

    </LinearLayout>

    <!-- Time Card: 72x17 → 84x20 -->
    <LinearLayout
        android:id="@+id/card_time_diff"
        android:layout_width="84dp"
        android:layout_height="20dp"
        android:layout_centerHorizontal="true"
        android:layout_alignParentBottom="true"
        android:layout_marginBottom="9dp"
        android:orientation="horizontal"
        android:gravity="center"
        android:background="@drawable/bg_time_card">

        <TextView
            android:id="@+id/tv_time_diff"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🕐 1h diff"
            android:textColor="#FFFFFF"
            android:textSize="8sp"
            android:textStyle="bold"
            android:singleLine="true"
            android:shadowColor="#AA8B0050"
            android:shadowDx="0"
            android:shadowDy="1"
            android:shadowRadius="3" />

    </LinearLayout>

</RelativeLayout>